# =========================
# DATABASE
# =========================
DB_URL=jdbc:h2:mem:testdb
DB_USER=sa
DB_PASS=
DDL_AUTO=update
SHOW_SQL=true
H2_CONSOLE=true

# =========================
# SECURITY
# =========================
JWT_SECRET=my-super-secret-key-12345678901234567890abcdef
JWT_EXPIRATION=3600000

# =========================
# VALIDATION
# =========================
PASSWORD_REGEX=^(?=.*[A-Z])(?=.*[a-z])(?=.*\d).{8,}$